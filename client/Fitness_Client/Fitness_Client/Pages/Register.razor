@page "/register"
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Регистрация</PageTitle>

<div class="auth-shell">
    <div class="auth-card">
        <p class="eyebrow">Регистрация клиента</p>
        <h1 class="hero">Создать аккаунт</h1>
        <p class="subtitle">После регистрации клиент сможет войти, смотреть абонемент, занятия, план и писать тренеру.</p>

        @if (!string.IsNullOrWhiteSpace(statusMessage))
        {
            <div class="alert-strip success">@statusMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="alert-strip">@errorMessage</div>
        }

        @if (isAuthorized)
        {
            <div class="alert-strip success">Вы уже вошли в систему. Регистрация будет доступна после выхода из аккаунта.</div>
        }

        <EditForm Model="@registration" OnValidSubmit="HandleRegister">
            <div class="auth-grid">
                <InputText class="auth-input" @bind-Value="registration.Name" placeholder="ФИО" disabled="@(isAuthorized || isBusy)" />
                <InputText class="auth-input" @bind-Value="registration.Phone" placeholder="Телефон" disabled="@(isAuthorized || isBusy)" />
                <InputText class="auth-input" @bind-Value="registration.Email" placeholder="Email" disabled="@(isAuthorized || isBusy)" />
                <InputText class="auth-input" @bind-Value="registration.Password" placeholder="Пароль" type="password" disabled="@(isAuthorized || isBusy)" />
            </div>
            <button class="btn-main auth-button" type="submit" disabled="@(isAuthorized || isBusy)">
                @(isAuthorized ? "Вы уже вошли" : isBusy ? "Регистрация..." : "Зарегистрироваться")
            </button>
        </EditForm>

        <p class="switch-text">Уже есть аккаунт? <NavLink href="login">Вход</NavLink></p>
    </div>
</div>

@code {
    private RegistrationRequestModel registration = new();
    private string statusMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool isAuthorized;
    private bool isBusy;

    protected override async Task OnInitializedAsync()
    {
        var session = await AuthService.GetStoredSessionAsync();
        isAuthorized = !string.IsNullOrWhiteSpace(session?.Token);
    }

    private async Task HandleRegister()
    {
        if (isAuthorized || isBusy)
        {
            return;
        }

        errorMessage = string.Empty;
        statusMessage = string.Empty;
        isBusy = true;

        var result = await AuthService.RegisterAsync(registration);
        isBusy = false;

        if (result is not null && result.Status)
        {
            statusMessage = string.IsNullOrWhiteSpace(result.Message) ? "Регистрация прошла успешно." : result.Message;
            await Task.Delay(800);
            Navigation.NavigateTo("/login", true);
            return;
        }

        errorMessage = string.IsNullOrWhiteSpace(result?.Message) ? "Не удалось зарегистрироваться." : result!.Message;
    }
}
