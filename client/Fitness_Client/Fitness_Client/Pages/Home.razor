@page "/"
@using Microsoft.AspNetCore.SignalR.Client
@inject ApiService Api
@inject AuthService AuthService
@inject NavigationManager Navigation
@implements IAsyncDisposable

<PageTitle>Панель</PageTitle>

@if (currentUser is null)
{
    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-strip">@errorMessage</div>
    }
    <p class="subtitle">@(isLoading ? "Загрузка панели..." : "Не удалось загрузить панель.")</p>
}
else
{
    <div class="page-header">
        <div>
            <h1>Панель управления клубом</h1>
            <p>@currentUser.Name, роль: @RoleName(currentUser.Role)</p>
        </div>
        <button class="btn-sub" @onclick="RefreshDashboard">Обновить</button>
    </div>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="alert-strip success">@statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="alert-strip">@errorMessage</div>
    }

    @if (IsAdminOrSales && summary is not null)
    {
        <div class="kpi-grid">
            <div class="kpi"><span>Активные абонементы</span><strong>@summary.Active</strong></div>
            <div class="kpi"><span>Заморожены</span><strong>@summary.Frozen</strong></div>
            <div class="kpi"><span>Посещения</span><strong>@summary.Attendance</strong></div>
            <div class="kpi"><span>Заполненность</span><strong>@summary.Occupancy%</strong></div>
            <div class="kpi"><span>Выручка</span><strong>@summary.Revenue ₽</strong></div>
            <div class="kpi"><span>Планы в работе</span><strong>@summary.PlansInProgress</strong></div>
        </div>
    }

    <div class="dashboard-grid">
        @if (IsAdmin)
        {
            <section class="panel">
                <h2>Пользователи</h2>
                <div class="form-grid">
                    <input @bind="newUser.Name" placeholder="ФИО" />
                    <input @bind="newUser.Email" placeholder="Email" />
                    <input @bind="newUser.Password" placeholder="Пароль" />
                    <select @bind="newUser.Role_Id">
                        <option value="2">Клиент</option>
                        <option value="3">Тренер</option>
                        <option value="4">Менеджер продаж</option>
                    </select>
                    <input @bind="newUser.Phone" placeholder="Телефон клиента" />
                    <input @bind="newUser.Specialization" placeholder="Специализация тренера" />
                </div>
                <button class="btn-main" @onclick="CreateUser">Создать пользователя</button>

                <div class="table-list">
                    @foreach (var user in users)
                    {
                        <div class="row-line">
                            <span>@user.Name</span>
                            <span>@RoleName(user.Role)</span>
                            <span>@user.Email</span>
                        </div>
                    }
                </div>
            </section>
        }

        @if (IsAdminOrSales)
        {
            <section class="panel">
                <h2>Абонементы</h2>
                <p class="section-kicker">Клиент</p>
                <div class="form-grid">
                    <input @bind="newClient.FullName" placeholder="ФИО клиента" />
                    <input @bind="newClient.Phone" placeholder="Телефон" />
                </div>
                <button class="btn-sub" @onclick="CreateClient">Добавить клиента</button>

                <p class="section-kicker">Оформление абонемента</p>
                <div class="form-grid">
                    <select @bind="newMembership.ClientId">
                        <option value="0">Выберите клиента</option>
                        @foreach (var client in clients)
                        {
                            <option value="@client.Id">@client.FullName</option>
                        }
                    </select>
                    <select @bind="newMembership.Type">
                        @foreach (var tariff in membershipTariffs)
                        {
                            <option value="@tariff.Name">@tariff.Name</option>
                        }
                    </select>
                    <input @bind="newMembership.StartDate" type="date" @bind:format="yyyy-MM-dd" />
                    <input value="@CalculatedMembershipEnd.ToString("dd.MM.yyyy")" disabled />
                </div>
                <div class="tariff-preview">
                    <strong>@SelectedTariff.Name</strong>
                    <span>@SelectedTariff.Description</span>
                    <span>@MembershipPeriodText</span>
                </div>
                @if (!clients.Any())
                {
                    <p class="section-note">В базе пока нет клиентов. Добавьте клиента выше или зарегистрируйте клиентский аккаунт.</p>
                }
                <button class="btn-main" disabled="@(!clients.Any())" @onclick="CreateMembership">Оформить абонемент</button>
                <button class="btn-sub" @onclick="LoadReminders">Проверить окончания</button>

                <div class="table-list">
                    @foreach (var membership in memberships.Take(10))
                    {
                        <div class="row-line">
                            <span>@ClientName(membership.ClientId)</span>
                            <span>@membership.Type</span>
                            <span>@StatusName(membership.Status)</span>
                            <span>с @membership.StartDate.ToShortDateString() до @membership.EndDate.ToShortDateString()</span>
                            <span class="row-actions">
                                @if (membership.Status == "Frozen")
                                {
                                    <button class="btn-sub" @onclick="() => UnfreezeMembership(membership.Id)">Разморозить</button>
                                }
                                else
                                {
                                    <button class="btn-sub" @onclick="() => FreezeMembership(membership.Id)">Заморозить</button>
                                }
                                <button class="btn-sub" @onclick="() => ExtendMembership(membership.Id)">Продлить на 30 дней</button>
                            </span>
                        </div>
                    }
                </div>

                @if (reminders.Any())
                {
                    <p class="section-note">Скоро заканчиваются:</p>
                    @foreach (var reminder in reminders.Take(5))
                    {
                        <div class="mini-line">@ClientName(reminder.ClientId), до @reminder.EndDate.ToShortDateString()</div>
                    }
                }
            </section>
        }

        @if (IsAdmin || IsTrainer)
        {
            <section class="panel">
                <h2>Расписание занятий</h2>
                @if (IsTrainer && myTrainer is not null)
                {
                    <p class="section-note">@myTrainer.FullName, @myTrainer.Specialization</p>
                }
                <div class="form-grid">
                    <input @bind="newWorkout.Title" placeholder="Название занятия" />
                    @if (IsAdmin)
                    {
                        <select @bind="newWorkout.TrainerId">
                            <option value="0">Выберите тренера</option>
                            @foreach (var trainer in trainers)
                            {
                                <option value="@trainer.Id">@trainer.FullName</option>
                            }
                        </select>
                    }
                    <input @bind="newWorkout.StartAt" type="datetime-local" @bind:format="yyyy-MM-ddTHH:mm" />
                    <input @bind="newWorkout.Capacity" type="number" placeholder="Количество мест" />
                </div>
                <button class="btn-main" @onclick="CreateWorkout">Добавить занятие</button>

                <div class="table-list">
                    @foreach (var workout in workouts.Take(12))
                    {
                        <div class="row-line">
                            <span>@workout.Title</span>
                            <span>@TrainerName(workout.TrainerId)</span>
                            <span>@workout.StartAt.ToString("dd.MM HH:mm")</span>
                            <span>@workout.ClientIds.Count / @workout.Capacity мест</span>
                        </div>
                    }
                </div>
            </section>
        }

        @if (IsSales)
        {
            <section class="panel">
                <h2>Клиенты</h2>
                <div class="table-list">
                    @foreach (var client in clients.Take(16))
                    {
                        <div class="row-line">
                            <span>@client.FullName</span>
                            <span>@client.Phone</span>
                        </div>
                    }
                </div>
            </section>
        }

        @if (IsTrainer)
        {
            <section class="panel">
                <h2>Планы клиентов</h2>
                <div class="form-grid">
                    <select @bind="newPlan.ClientId">
                        <option value="0">Выберите клиента</option>
                        @foreach (var client in clients)
                        {
                            <option value="@client.Id">@client.FullName</option>
                        }
                    </select>
                    <input @bind="newPlan.TrainingPlan" placeholder="План тренировок" />
                    <input @bind="newPlan.NutritionPlan" placeholder="План питания" />
                    <input @bind="progressValue" type="number" placeholder="Прогресс %" />
                    <select @bind="progressPlanId">
                        <option value="0">План для обновления</option>
                        @foreach (var plan in plans)
                        {
                            <option value="@plan.Id">@ClientName(plan.ClientId), план #@plan.Id</option>
                        }
                    </select>
                </div>
                <button class="btn-main" @onclick="CreatePlan">Создать план</button>
                <button class="btn-sub" @onclick="UpdatePlanProgress">Обновить прогресс</button>

                <div class="table-list">
                    @foreach (var plan in plans)
                    {
                        <div class="row-line">
                            <span>@ClientName(plan.ClientId)</span>
                            <span>@plan.TrainingPlan</span>
                            <span>@plan.ProgressPercent%</span>
                        </div>
                    }
                </div>
            </section>

        }

        @if (IsClient)
        {
            <section class="panel">
                <h2>Мой абонемент и посещения</h2>
                @if (myClient is not null)
                {
                    <p class="section-note">@myClient.FullName, @myClient.Phone</p>
                }
                <button class="btn-main" disabled="@(ActiveVisitId.HasValue || !HasCurrentActiveMembership)" @onclick="EnterClub">
                    @(ActiveVisitId.HasValue ? "Вход уже отмечен" : HasCurrentActiveMembership ? "Отметить вход" : "Нет активного абонемента")
                </button>
                @if (ActiveVisitId.HasValue)
                {
                    <button class="btn-sub" @onclick="ExitClub">Отметить выход</button>
                }

                <div class="table-list">
                    @foreach (var membership in memberships)
                    {
                        <div class="row-line">
                            <span>@membership.Type</span>
                            <span>@StatusName(membership.Status)</span>
                            <span>с @membership.StartDate.ToShortDateString() до @membership.EndDate.ToShortDateString()</span>
                        </div>
                    }
                    @foreach (var visit in visits.Take(8))
                    {
                        <div class="row-line">
                            <span>Вход: @visit.EnteredAt.ToString("dd.MM HH:mm")</span>
                            <span>Выход: @(visit.ExitedAt?.ToString("dd.MM HH:mm") ?? "в клубе")</span>
                        </div>
                    }
                </div>
            </section>

            <section class="panel">
                <h2>Занятия</h2>
                <div class="table-list">
                    @foreach (var workout in workouts.Take(12))
                    {
                        <div class="row-line">
                            <span>@workout.Title</span>
                            <span>@TrainerName(workout.TrainerId)</span>
                            <span>@workout.StartAt.ToString("dd.MM HH:mm")</span>
                            <span>@workout.ClientIds.Count / @workout.Capacity мест</span>
                            <button class="btn-sub" disabled="@(!CanEnroll(workout))" @onclick="() => EnrollClient(workout.Id)">@WorkoutActionName(workout)</button>
                        </div>
                    }
                </div>
            </section>

            <section class="panel">
                <h2>Мой план</h2>
                <div class="table-list">
                    @foreach (var plan in plans)
                    {
                        <div class="row-line">
                            <span>Тренировки: @plan.TrainingPlan</span>
                        </div>
                        <div class="row-line">
                            <span>Питание: @plan.NutritionPlan</span>
                            <span>Прогресс: @plan.ProgressPercent%</span>
                        </div>
                    }
                </div>
            </section>

        }

        <section class="panel">
            <h2>Журнал активности</h2>
            <p class="section-note">Сообщения, push-уведомления и изменения записи на занятия.</p>
            <div class="table-list">
                @foreach (var log in liveLog.TakeLast(10).Reverse())
                {
                    <div class="mini-line">@log</div>
                }
                @if (!liveLog.Any())
                {
                    <div class="mini-line">Новых уведомлений пока нет.</div>
                }
            </div>
        </section>
    </div>
}

@code {
    private UserSessionModel? currentUser;
    private ReportSummaryModel? summary;
    private List<UserSessionModel> users = new();
    private List<ClientModel> clients = new();
    private List<TrainerModel> trainers = new();
    private List<MembershipModel> memberships = new();
    private List<MembershipModel> reminders = new();
    private List<WorkoutModel> workouts = new();
    private List<PlanModel> plans = new();
    private List<VisitModel> visits = new();
    private List<ChatMessageModel> chatFeed = new();
    private List<PushNotificationModel> pushes = new();
    private List<string> liveLog = new();

    private CreateUserRequestModel newUser = new() { Role_Id = 4 };
    private ClientModel newClient = new();
    private MembershipModel newMembership = new() { Type = "Стандарт", StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(30) };
    private WorkoutModel newWorkout = new() { StartAt = DateTime.Now, Capacity = 12 };
    private PlanModel newPlan = new();
    private SendChatRequestModel trainerChat = new();
    private SendPushRequestModel trainerPush = new();
    private SendChatRequestModel clientChat = new();

    private ClientModel? myClient;
    private TrainerModel? myTrainer;
    private int progressPlanId;
    private int progressValue;
    private string statusMessage = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = true;
    private HubConnection? hub;
    private readonly List<MembershipTariff> membershipTariffs = new()
    {
        new MembershipTariff("Разовое посещение", 1, "Доступ в клуб на один выбранный день."),
        new MembershipTariff("Дневной", 30, "30 дней посещений в дневное время."),
        new MembershipTariff("Стандарт", 30, "30 дней тренировок по обычному тарифу."),
        new MembershipTariff("Премиум", 30, "30 дней с расширенным доступом и поддержкой тренера."),
        new MembershipTariff("Безлимит", 90, "90 дней без ограничения по количеству посещений.")
    };

    private MembershipTariff SelectedTariff => membershipTariffs.FirstOrDefault(x => x.Name == newMembership.Type) ?? membershipTariffs[2];
    private DateTime CalculatedMembershipEnd => newMembership.StartDate.Date.AddDays(SelectedTariff.Days - 1);
    private string MembershipPeriodText => SelectedTariff.Days == 1
        ? $"Дата посещения: {newMembership.StartDate:dd.MM.yyyy}"
        : $"Период: {newMembership.StartDate:dd.MM.yyyy} - {CalculatedMembershipEnd:dd.MM.yyyy}";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var sessionTask = AuthService.GetStoredSessionAsync();
            var completedTask = await Task.WhenAny(sessionTask, Task.Delay(TimeSpan.FromSeconds(3)));

            if (completedTask != sessionTask)
            {
                errorMessage = "Не удалось прочитать сессию браузера. Обновите страницу или войдите заново.";
                return;
            }

            var session = await sessionTask;
            if (string.IsNullOrWhiteSpace(session?.Token) || session.User is null)
            {
                await RedirectToLogin();
                return;
            }

            currentUser = session.User;
            isLoading = false;
            await InvokeAsync(StateHasChanged);

            await LoadDashboard();
            _ = StartHub();
        }
        catch
        {
            errorMessage = "Не удалось загрузить панель. Проверьте, что Fitness_Api запущен.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private bool IsAdmin => currentUser?.Role == "Administrator";
    private bool IsSales => currentUser?.Role == "SalesManager";
    private bool IsTrainer => currentUser?.Role == "Trainer";
    private bool IsClient => currentUser?.Role == "Client";
    private bool IsAdminOrSales => IsAdmin || IsSales;
    private int? ActiveVisitId => visits.FirstOrDefault(x => x.ExitedAt is null)?.Id;
    private bool HasCurrentActiveMembership => memberships.Any(x =>
        x.Status == "Active"
        && x.StartDate.Date <= DateTime.Today
        && x.EndDate.Date >= DateTime.Today);

    private async Task RefreshDashboard()
    {
        await LoadDashboard();
    }

    private async Task LoadDashboard(bool clearMessages = true)
    {
        if (clearMessages)
        {
            statusMessage = string.Empty;
            errorMessage = string.Empty;
        }

        memberships = new();
        workouts = new();
        plans = new();
        visits = new();
        chatFeed = new();
        pushes = new();
        reminders = new();
        users = new();
        clients = new();
        trainers = new();

        if (IsAdmin)
        {
            summary = await SafeLoad(() => Api.GetSummary());
            users = (await SafeLoad(() => Api.GetUsers()))?.Users ?? new();
            clients = await SafeLoad(() => Api.GetClients()) ?? new();
            trainers = await SafeLoad(() => Api.GetTrainers()) ?? new();
            memberships = await SafeLoad(() => Api.GetMemberships()) ?? new();
            workouts = await SafeLoad(() => Api.GetWorkouts()) ?? new();
            chatFeed = await SafeLoad(() => Api.GetChat()) ?? new();
        }

        if (IsSales)
        {
            summary = await SafeLoad(() => Api.GetSummary());
            clients = await SafeLoad(() => Api.GetClients()) ?? new();
            memberships = await SafeLoad(() => Api.GetMemberships()) ?? new();
        }

        if (IsTrainer)
        {
            myTrainer = await SafeLoad(() => Api.GetMyTrainer());
            clients = await SafeLoad(() => Api.GetClients()) ?? new();
            workouts = await SafeLoad(() => Api.GetWorkouts()) ?? new();
            plans = await SafeLoad(() => Api.GetPlans()) ?? new();
            chatFeed = await SafeLoad(() => Api.GetChat()) ?? new();
            pushes = await SafeLoad(() => Api.GetPush()) ?? new();
        }

        if (IsClient)
        {
            myClient = await SafeLoad(() => Api.GetMyClient());
            memberships = await SafeLoad(() => Api.GetMemberships()) ?? new();
            workouts = await SafeLoad(() => Api.GetWorkouts()) ?? new();
            plans = await SafeLoad(() => Api.GetPlans()) ?? new();
            visits = await SafeLoad(() => Api.GetVisits()) ?? new();
            chatFeed = await SafeLoad(() => Api.GetChat()) ?? new();
            pushes = await SafeLoad(() => Api.GetPush()) ?? new();
        }
    }

    private async Task<T?> SafeLoad<T>(Func<Task<T?>> action)
    {
        try
        {
            var loadTask = action();
            var completedTask = await Task.WhenAny(loadTask, Task.Delay(TimeSpan.FromSeconds(6)));

            if (completedTask != loadTask)
            {
                errorMessage = "Не удалось загрузить часть данных. Проверьте запуск API.";
                return default;
            }

            return await loadTask;
        }
        catch
        {
            errorMessage = "Не удалось загрузить часть данных. Проверьте запуск API.";
            return default;
        }
    }

    private async Task<string> ReadApiMessage(HttpResponseMessage response, string fallback)
    {
        try
        {
            var result = await response.Content.ReadFromJsonAsync<ApiStatusResponseModel>();
            return string.IsNullOrWhiteSpace(result?.Message) ? fallback : result.Message;
        }
        catch
        {
            return fallback;
        }
    }

    private async Task RedirectToLogin()
    {
        await AuthService.ClearSessionAsync();
        Navigation.NavigateTo("/login");
    }

    private async Task StartHub()
    {
        var session = await AuthService.GetStoredSessionAsync();
        if (string.IsNullOrWhiteSpace(session?.Token))
        {
            return;
        }

        hub = new HubConnectionBuilder()
            .WithUrl("http://localhost:5294/hubs/chat", options =>
            {
                options.AccessTokenProvider = () => Task.FromResult<string?>(session.Token);
            })
            .WithAutomaticReconnect()
            .Build();

        hub.On<object>("ChatConnected", _ =>
        {
            liveLog.Add("Live-журнал подключен.");
            InvokeAsync(StateHasChanged);
        });

        hub.On<ChatMessageModel>("ReceiveChatMessage", message =>
        {
            if (IsChatMessageVisible(message) && chatFeed.All(x => x.Id != message.Id))
            {
                chatFeed.Add(message);
                liveLog.Add($"Новое сообщение: {message.Text}");
                InvokeAsync(StateHasChanged);
            }
        });

        hub.On<PushNotificationModel>("PushNotification", push =>
        {
            pushes.Insert(0, push);
            liveLog.Add($"Уведомление: {push.Text}");
            InvokeAsync(StateHasChanged);
        });

        hub.On<object>("WorkoutChanged", _ =>
        {
            liveLog.Add("Изменилась запись на занятие.");
            InvokeAsync(StateHasChanged);
        });

        try
        {
            var startTask = hub.StartAsync();
            var completedTask = await Task.WhenAny(startTask, Task.Delay(TimeSpan.FromSeconds(4)));

            if (completedTask == startTask)
            {
                await startTask;
            }
            else
            {
                liveLog.Add("Live-журнал недоступен.");
            }
        }
        catch
        {
            liveLog.Add("Live-журнал недоступен.");
        }
    }

    private async Task CreateUser()
    {
        var response = await Api.CreateUser(newUser);
        if (response.IsSuccessStatusCode)
        {
            newUser = new() { Role_Id = 4 };
            await LoadDashboard(false);
            statusMessage = "Пользователь создан.";
            errorMessage = string.Empty;
            return;
        }

        statusMessage = string.Empty;
        errorMessage = await ReadApiMessage(response, "Не удалось создать пользователя.");
    }

    private async Task CreateClient()
    {
        if (string.IsNullOrWhiteSpace(newClient.FullName))
        {
            errorMessage = "Введите ФИО клиента.";
            return;
        }

        var response = await Api.AddClient(newClient);
        if (response.IsSuccessStatusCode)
        {
            newClient = new();
            await LoadDashboard(false);
            statusMessage = "Клиент добавлен.";
            errorMessage = string.Empty;
            return;
        }

        statusMessage = string.Empty;
        errorMessage = await ReadApiMessage(response, "Не удалось добавить клиента.");
    }

    private async Task CreateMembership()
    {
        if (newMembership.ClientId == 0)
        {
            errorMessage = "Выберите клиента для абонемента.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newMembership.Type))
        {
            errorMessage = "Выберите тип абонемента.";
            return;
        }

        newMembership.StartDate = DateTime.SpecifyKind(newMembership.StartDate.Date, DateTimeKind.Unspecified);
        newMembership.EndDate = DateTime.SpecifyKind(CalculatedMembershipEnd, DateTimeKind.Unspecified);
        newMembership.Status = "Active";

        if (HasMembershipOverlap(newMembership.ClientId, newMembership.StartDate, newMembership.EndDate))
        {
            errorMessage = "У клиента уже есть абонемент на этот период. Продлите текущий или выберите дату после его окончания.";
            return;
        }

        var response = await Api.AddMembership(newMembership);
        if (response.IsSuccessStatusCode)
        {
            newMembership = new() { Type = "Стандарт", StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(29) };
            await LoadDashboard(false);
            statusMessage = "Абонемент оформлен.";
            errorMessage = string.Empty;
            return;
        }

        statusMessage = string.Empty;
        errorMessage = await ReadApiMessage(response, "Не удалось оформить абонемент.");
    }

    private async Task FreezeMembership(int id)
    {
        var response = await Api.FreezeMembership(id);
        await LoadDashboard(false);
        statusMessage = response.IsSuccessStatusCode ? "Абонемент заморожен." : string.Empty;
        errorMessage = response.IsSuccessStatusCode ? string.Empty : await ReadApiMessage(response, "Не удалось заморозить абонемент.");
    }

    private async Task UnfreezeMembership(int id)
    {
        var response = await Api.UnfreezeMembership(id);
        await LoadDashboard(false);
        statusMessage = response.IsSuccessStatusCode ? "Абонемент разморожен." : string.Empty;
