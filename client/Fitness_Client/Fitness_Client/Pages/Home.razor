    private async Task<string?> SendChatMessage(SendChatRequestModel message)
    {
        if (await EnsureChatHubConnected())
        {
            try
            {
                await hub!.InvokeAsync("SendChatMessage", message);
                return null;
            }
            catch
            {
                liveLog.Add("Live-журнал недоступен, сообщение отправляется через API.");
            }
        }

        var response = await Api.SendChat(message);
        return response.IsSuccessStatusCode
            ? null
            : await ReadApiMessage(response, "Не удалось отправить сообщение.");
    }

    private async Task<bool> EnsureChatHubConnected()
    {
        if (hub?.State == HubConnectionState.Connected)
        {
            return true;
        }

        await StartHub();
        return hub?.State == HubConnectionState.Connected;
    }

    private bool IsChatMessageVisible(ChatMessageModel message)
    {
        if (IsAdmin)
        {
            return true;
        }

        if (IsTrainer && currentUser?.Trainer_Id == message.TrainerId)
        {
            return true;
        }

        return IsClient && currentUser?.Client_Id == message.ClientId;
    }

    private RenderFragment ChatList() => builder =>
    {
        var messages = chatFeed.TakeLast(12).Reverse().ToList();
        if (!messages.Any())
        {
            builder.OpenElement(0, "div");
            builder.AddAttribute(1, "class", "mini-line");
            builder.AddContent(2, "Сообщений пока нет.");
            builder.CloseElement();
            return;
        }

        var sequence = 3;
        builder.OpenElement(sequence++, "div");
        builder.AddAttribute(sequence++, "class", "chat-list");
        foreach (var message in messages)
        {
            builder.OpenElement(sequence++, "div");
            builder.AddAttribute(sequence++, "class", "chat-message");
            builder.OpenElement(sequence++, "strong");
            builder.AddContent(sequence++, SenderName(message.SenderRole));
            builder.CloseElement();
            builder.OpenElement(sequence++, "span");
            builder.AddContent(sequence++, message.Text);
            builder.CloseElement();
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private string RoleName(string? role)
    {
        return role switch
        {
            "Administrator" => "Администратор",
            "SalesManager" => "Менеджер продаж",
            "Trainer" => "Тренер",
            "Client" => "Клиент",
            _ => role ?? string.Empty
        };
    }

    private string StatusName(string status)
    {
        return status switch
        {
            "Active" => "Активен",
            "Frozen" => "Заморожен",
            "Expired" => "Истёк",
            _ => status
        };
    }

    private string SenderName(string role)
    {
        return role switch
        {
            "Trainer" => "Тренер",
            "Client" => "Клиент",
            _ => "Пользователь"
        };
    }

    private string ClientName(int id)
    {
        return clients.FirstOrDefault(x => x.Id == id)?.FullName ?? $"Клиент #{id}";
    }

    private string TrainerName(int id)
    {
        return trainers.FirstOrDefault(x => x.Id == id)?.FullName ?? $"Тренер #{id}";
    }

    private bool HasMembershipOverlap(int clientId, DateTime startDate, DateTime endDate)
    {
        return memberships.Any(x => x.ClientId == clientId
            && x.Status != "Expired"
            && x.StartDate.Date <= endDate.Date
            && startDate.Date <= x.EndDate.Date);
    }

    private bool CanEnroll(WorkoutModel workout)
    {
        return HasCurrentActiveMembership
            && workout.StartAt > DateTime.Now
            && workout.ClientIds.Count < workout.Capacity
            && !workout.ClientIds.Contains(currentUser?.Client_Id ?? 0);
    }

    private string WorkoutActionName(WorkoutModel workout)
    {
        if (workout.ClientIds.Contains(currentUser?.Client_Id ?? 0))
        {
            return "Вы записаны";
        }

        if (workout.StartAt <= DateTime.Now)
        {
            return "Занятие прошло";
        }

        if (workout.ClientIds.Count >= workout.Capacity)
        {
            return "Мест нет";
        }

        return HasCurrentActiveMembership ? "Записаться" : "Нужен абонемент";
    }

